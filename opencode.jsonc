{
  "$schema": "https://opencode.ai/config.json",
  
  // MCP Server Configuration
  "mcp": {
    // Context7 - Remote documentation search
    "context7": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp"
    },
    
    // LLM Wiki - Local knowledge base
    "servers": {
      "llm-wiki": {
        "command": "node",
        "args": ["src-mcp/src/server.js"],
        "env": {
          // Project root will be set to workspace folder
          "LLM_WIKI_PROJECT": "${workspaceFolder}"
        }
      }
    }
  }
}
